# Hivemind APIs
HIVEMIND_API_KEY=
HIVEMIND_INTELLIGENCE_API_KEY=
HIVEMIND_BASE_URL=https://hivemind.myosin.xyz

# OpenAI (image generation)
OPENAI_API_KEY=

# LinkedIn — used by scripts/li_*.py at runtime. Onboarding writes these into the
# environment + workspace/.tokens.env. Set here only if running CLI scripts directly.
LINKEDIN_ACCESS_TOKEN=

# Facebook — same pattern as LinkedIn. FACEBOOK_PAGE_ID is required for ad creative creation.
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Default ad containers (used when /drafts/:id/push doesn't supply IDs — convenient for demo)
LI_DEFAULT_CAMPAIGN_ID=
FB_DEFAULT_ADSET_ID=

# Optional: pre-warm script for Aurevon's intelligence reports
AUREVON_PROJECT_ID=
