# Hivemind API
HIVEMIND_API_KEY=hm_k_...
HIVEMIND_BASE_URL=https://hivemind.myosin.xyz

# Public demo mode
# ADPILOT_DEMO_MODE=true seeds a demo workspace, mock ads, and mock analytics.
# ADPILOT_DEMO_PASSWORD gates the Next app. Leave blank for local ungated dev.
# ADPILOT_BACKEND_SECRET protects the public FastAPI sidecar; set the same value on the backend and frontend.
ADPILOT_DEMO_MODE=false
ADPILOT_DEMO_PASSWORD=
ADPILOT_BACKEND_SECRET=
ADPILOT_CORS_ORIGINS=http://localhost:3000
ADPILOT_API_BASE=http://127.0.0.1:8000
ADPILOT_DEMO_MOCK_DIAGNOSE=true

# OpenAI (image generation)
OPENAI_API_KEY=

# LinkedIn / Facebook tokens — collected through the in-app credentials panel
# the first time you push a draft. The panel writes them to workspace/.tokens.env
# and reloads them on server start. Only set here if running scripts/ directly.
LINKEDIN_ACCESS_TOKEN=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Default ad containers (used when /drafts/:id/push doesn't supply IDs — convenient for demo)
LI_DEFAULT_CAMPAIGN_ID=
FB_DEFAULT_ADSET_ID=
